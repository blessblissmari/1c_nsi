# ---------------------------------------------------------------------------
# Инструмент НСИ — пример конфигурации
# Скопируйте в .env и заполните реальные значения.
# ---------------------------------------------------------------------------

# === Application ===
APP_ENV=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# === HTTP / CORS ===
# Через запятую; для prod укажите точный origin фронта
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Максимальный размер загружаемого файла (МБ)
MAX_UPLOAD_MB=50

# === База данных ===
# SQLite (dev):
DATABASE_URL=sqlite:///./backend/nsi_data.db
# Postgres (prod, пример):
# DATABASE_URL=postgresql+psycopg2://nsi:nsi@postgres:5432/nsi

# === Безопасность / JWT ===
# Сгенерируйте: `python -c "import secrets; print(secrets.token_urlsafe(64))"`
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=1440

# Первичный администратор (создаётся при `python -m app.seed --admin`)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# === AI-бэкенд ===
# openai | yandex. Если не задано, но есть OPENAI_API_KEY и нет YANDEX_API_KEY — openai.
AI_BACKEND=openai

# === OpenAI (или любой OpenAI-совместимый endpoint) ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Yandex AI Studio (опционально, альтернатива OpenAI) ===
YANDEX_API_KEY=
YANDEX_IDENTIFICATOR=          # folder_id
MODEL_URL=                      # gpt://<folder>/yandexgpt/latest
VECTOR_STORE_IDENTIFICATOR=

# === MinerU (PDF парсер) ===
MINERU_API_KEY=

# === Пути (обычно менять не нужно) ===
UPLOAD_DIR=backend/app/uploads
SEED_DATA_DIR=./ДОКУМЕНТЫ ДЛЯ РАБОТЫ
